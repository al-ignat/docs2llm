{
  "name": "docs2llm",
  "description": "Turn documents into LLM-ready Markdown. PDF, DOCX, PPTX, XLSX, HTML, images, URLs — local-first, one command.",
  "version": "2.0.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/al-ignat/docs2llm.git"
  },
  "files": ["src/**/*.ts", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:raycast": "bun run scripts/build-raycast.ts",
    "dev": "bun run src/commands/cli.ts",
    "test": "bun test",
    "test:raycast": "npm --prefix raycast test",
    "typecheck": "tsc --noEmit",
    "eval:run": "bun run eval/run.ts",
    "verify": "bun run typecheck && bun test && npm --prefix raycast test && bun run build && bun run build:raycast"
  },
  "bin": {
    "docs2llm": "src/commands/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.0",
    "@kreuzberg/node": "^4.5.1",
    "@kreuzberg/wasm": "^4.5.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "defuddle": "^0.14.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.2",
    "yaml": "^2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "typescript": "^5.8.2"
  }
}
